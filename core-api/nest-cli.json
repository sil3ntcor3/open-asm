{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "**/*.json",
      "**/*.yaml",
      "**/*.yml",
      "**/*.proto",
      "**/*.md",
      "**/*.ttf",
      "src/modules/agents/skills/**/*.md"
    ]
  }
}
